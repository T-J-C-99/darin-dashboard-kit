# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — your real secrets stay on your machine.

# Neon Postgres connection string.
# Get this from console.neon.tech after creating a project.
DATABASE_URL=postgres://user:pass@host/dbname

# Secret key for admin sync endpoints.
# Generate a long random string: `openssl rand -hex 32`
SYNC_API_KEY=replace-with-long-random-string

# Dashboard password. If set, visitors must enter this to view the dashboard.
# Leave blank for open access (fine for local dev).
DASHBOARD_PASSWORD=

# Feature flags — leave false unless you know what you're doing.
# Turning this on makes /demo show the original showcase with fake data.
NEXT_PUBLIC_DEMO_MODE=false
